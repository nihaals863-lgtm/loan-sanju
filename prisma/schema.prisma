generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
  BORROWER
  AGENT
  LENDER
}

enum LoanStatus {
  PENDING
  TERMS_SET
  TERMS_ACCEPTED
  FUNDS_CONFIRMED
  ACTIVE
  REJECTED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  VERIFIED
  LATE
}

enum PaymentType {
  MONTHLY_INTEREST
  PRINCIPAL_PAYDOWN
  PAYOFF
}

enum PaymentMethod {
  CASH
  WIRE
  TRX
  MOBILE_MONEY
  BANK_TRANSFER
}

enum Risk {
  GREEN
  AMBER
  RED
}
  

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  phone      String   @unique
  password   String
  role       Role     @default(BORROWER)
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  status     String   @default("pending_approval") // pending_approval, active, suspended
  risk       Risk     @default(GREEN)
  
  // Profile Fields
  businessName String?
  nrc          String?  @unique
  dob          DateTime?
  address      String?  @db.Text
  documentUrl  String?  @db.LongText
  referralCode String?  @unique

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  loans                 Loan[]
  loansAsAgent          Loan[] @relation("LoanAgent")
  collaterals           Collateral[]
  agentCommissions      Commission[] @relation("AgentCommissions")
  borrowerCommissions   Commission[] @relation("BorrowerCommissions")
  payouts               Payout[]
  notifications         Notification[]
  referralsMade         Referral[] @relation("Referrer")
  referralReceived      Referral? @relation("Referred")
  @@map("user")
}

model Referral {
  id          Int      @id @default(autoincrement())
  referrerId  Int
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id])
  referredId  Int      @unique
  referred    User     @relation("Referred", fields: [referredId], references: [id])
  
  status      String   @default("PENDING") // PENDING, QUALIFIED, REWARDED
  rewardAmount Decimal @db.Decimal(10, 2) @default(50.00)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("referral")
}

model Loan {
  id        Int        @id @default(autoincrement())
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
  agentId   Int?
  agent     User?      @relation("LoanAgent", fields: [agentId], references: [id])
  
  // Financial Terms
  principalAmount   Decimal @db.Decimal(15, 2)
  currentPrincipal  Decimal @db.Decimal(15, 2)
  initiationFeeRate Decimal @db.Decimal(5, 2) // %
  initiationFee     Decimal @db.Decimal(15, 2)
  disbursedAmount   Decimal @db.Decimal(15, 2)
  interestRate      Decimal @db.Decimal(5, 2) // % monthly
  
  dueDay            Int     @default(1)
  graceDays         Int     @default(0)
  latePenaltyRate   Decimal @db.Decimal(5, 2) @default(5.00) // %
  agentCommissionRate Decimal @db.Decimal(5, 2) @default(5.00) // %
  duration          Int     @default(1) // months
  monthlyPaymentCurrent Decimal @db.Decimal(15, 2) @default(0.00)

  status    LoanStatus @default(PENDING)
  
  // Flow tracking
  borrowerAcceptedTerms Boolean @default(false)
  termsAcceptedAt       DateTime?
  adminConfirmedFunds   Boolean @default(false)
  fundsConfirmedAt      DateTime?

  dueDate   DateTime?
  
  // Disbursement & Details
  disbursementMethod String?
  deliveryAddress    String?  @db.Text
  whatsapp           String?
  bankName           String?
  accountNumber      String?
  accountName        String?
  description        String?  @db.Text

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  payments    Payment[]
  commissions Commission[] @relation("LoanCommissions")
  @@map("loan") 
}

model Payment {
  id        Int           @id @default(autoincrement())
  loanId    Int
  loan      Loan          @relation(fields: [loanId], references: [id])
  
  type      PaymentType   @default(MONTHLY_INTEREST)
  
  baseAmount      Decimal @db.Decimal(15, 2) // interest component
  penaltyAmount   Decimal @db.Decimal(15, 2) @default(0)
  principalPaid   Decimal @db.Decimal(15, 2) @default(0)
  totalCollected  Decimal @db.Decimal(15, 2)
  dueDate         DateTime?     @db.Date

  lateDays    Int?
  
  status    PaymentStatus @default(PENDING)
  method    PaymentMethod @default(CASH)
  trxId     String?       @unique
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  @@map("payment")

}

enum CommissionStatus {
  PENDING
  PAID
}

enum PayoutStatus {
  PENDING
  COMPLETED
  REJECTED
}

model Payout {
  id          Int          @id @default(autoincrement())
  agentId     Int
  agent       User         @relation(fields: [agentId], references: [id])
  amount      Decimal      @db.Decimal(15, 2)
  status      PayoutStatus @default(PENDING)
  method      String?
  trxId       String?      @unique
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@map("payout")
  
}

model Commission {
  id         Int              @id @default(autoincrement())
  agentId    Int
  agent      User             @relation("AgentCommissions", fields: [agentId], references: [id])
  borrowerId Int
  borrower   User             @relation("BorrowerCommissions", fields: [borrowerId], references: [id])
  loanId     Int
  loan       Loan             @relation("LoanCommissions", fields: [loanId], references: [id])
  
  amount     Decimal          @db.Decimal(15, 2)
  percentage Decimal          @db.Decimal(5, 2)
  
  status     CommissionStatus @default(PENDING)
  paymentId  Int?
  
  createdAt  DateTime         @default(now())
  @@map("commission")
                       
}

model Collateral {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  name      String   @default("UNNAMED_ASSET")
  type      String   @default("FILE")
  imageUrl  String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
   @@map("collateral")
}

// ─── Notification ───────────────────────────
enum NotificationType {
  SMS
  EMAIL
  SYSTEM
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id])
  title     String
  message   String           @db.Text
  type      NotificationType @default(SYSTEM)
  status    String           @default("SENT") // SENT, FAILED
  error     String?          @db.Text
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
   @@map("notification")
          
}

// ─── Settings (System-wide config) ──────────
model Settings {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
   @@map("settings")
}



